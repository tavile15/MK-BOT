# Copie este ficheiro para ".env.testnet" na raiz do projeto e preencha.
# O ficheiro ".env.testnet" está no .gitignore — não commite chaves.
#
# Chaves obtidas em https://testnet.binance.vision (tipo HMAC_SHA256).

BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=

# Notificacao opcional no fim do soak (executor-loop).
# 1 = envia mensagem no Telegram ao encerrar o teste.
MT_TELEGRAM_ENABLED=0
MT_TELEGRAM_BOT_TOKEN=
MT_TELEGRAM_CHAT_ID=
# Opcional (foruns/topicos no Telegram):
# MT_TELEGRAM_THREAD_ID=
# Opcional (linha no topo da mensagem, ex.: [P4t Testnet VPS]):
# MT_TELEGRAM_PREFIX=
# Opcional: enviar também os ficheiros de validação (.json + .csv) no fim do soak.
# 1 = envia anexos; 0 = só mensagem de texto.
MT_TELEGRAM_SEND_REPORT_FILES=1
# Opcional: imagem enviada antes do relatório (caminho absoluto ou relativo à raiz do projeto).
# Ex.: indentidade_visual/Gemini_Generated_Image_nvrl3lnvrl3lnvrl.png
MT_TELEGRAM_HEADER_IMAGE=